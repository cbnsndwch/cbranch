{
  "name": "@cbranch/core",
  "version": "0.0.0",
  "private": true,
  "description": "Transport-agnostic Git orchestration (the GitEngine). Depends on @cbranch/rpc-contract types only.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cbranch/rpc-contract": "workspace:*",
    "chokidar": "^5.0.0",
    "effect": "4.0.0-beta.92"
  },
  "devDependencies": {
    "@types/node": "^26.0.1"
  }
}
