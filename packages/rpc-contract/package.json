      "default": "./dist/effect-rpc-adapter.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "effect": "4.0.0-beta.84"
  }
}
