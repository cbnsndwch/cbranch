{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "endOfLine": "lf",
  "sortImports": true,
  "sortTailwindcss": true,
  "ignorePatterns": ["**/*.md", "docs/**", "**/dist/**", "**/node_modules/**", "pnpm-lock.yaml"]
}
